# =============================================================================
# LLM API 密钥 — 拷贝为 llm_keys.env 后填入实际值
# =============================================================================
# 实际文件 backend/secrets/llm_keys.env 不进 git。
# 由 backend/litellm/client.py 在启动时通过 dotenv 加载。
#
# 路由配置见 backend/litellm/router.yaml，里面用 ${AIHUBMIX_API_KEY} 等占位。
# =============================================================================

# AIHubMix（中转 OpenAI / Anthropic / Google 等模型）
# 申请：https://aihubmix.com
AIHUBMIX_API_KEY=

# NVIDIA build（NIM 上的开源模型，如 Llama 系列）
# 申请：https://build.nvidia.com
NVIDIA_API_KEY=
