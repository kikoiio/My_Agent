# =============================================================================
# 第三方账号凭据 — 拷贝为 accounts.env 后填入实际值
# =============================================================================
# 实际文件 backend/secrets/accounts.env 不进 git（已在 .gitignore 中）。
#
# 使用：
#   cp backend/secrets/accounts.env.example backend/secrets/accounts.env
#   # 填好下面的字段
#   python scripts/bilibili_cookie_import.py
#   python scripts/pyncm_login.py
# =============================================================================


# =============================================================================
# B 站凭据：方法 A（推荐，最稳）—— 从 DevTools 手动复制 4 个 cookie
# =============================================================================
# 步骤：
#   1. Edge / Chrome 打开 https://www.bilibili.com 并登录
#   2. 按 F12 → Application 面板 → 左侧 Storage → Cookies → https://www.bilibili.com
#   3. 在右侧表格里找到这 4 个 cookie，把 Value 列贴进下面（**不要带引号**）：
#        SESSDATA       → BILIBILI_SESSDATA
#        bili_jct       → BILIBILI_BILI_JCT
#        buvid3         → BILIBILI_BUVID3
#        DedeUserID     → BILIBILI_DEDEUSERID
#   4. 跑 python scripts/bilibili_cookie_import.py
# 一份 cookie 大约可用 30 天，过期后回这里重贴一次即可。
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=
BILIBILI_DEDEUSERID=

# -----------------------------------------------------------------------------
# B 站凭据：方法 B（自动从浏览器 cookie 库读取）
# -----------------------------------------------------------------------------
# 注意：Edge / Chrome 自 2024 年起启用「应用层绑定加密」，browser-cookie3 解不开，
# 大概率失败。Firefox 不受影响，能稳定读取。如果方法 A 已填，本节将被忽略。
# 支持：edge / chrome / firefox / brave / chromium
BILIBILI_BROWSER=firefox
BILIBILI_BROWSER_PROFILE=


# =============================================================================
# 网易云音乐凭据：方法 A（推荐）—— 从 DevTools 手动复制 MUSIC_U cookie
# =============================================================================
# 步骤：
#   1. 浏览器打开 https://music.163.com 并登录
#   2. F12 → Application → Cookies → https://music.163.com
#   3. 找到 MUSIC_U 这一行，复制 Value 列贴到下面
#   4. 可选：__csrf 一起复制（提交类操作用得上，纯查询不需要）
#   5. 跑 python scripts/pyncm_login.py
# 一份 cookie 大约可用 6 个月，过期了回这里重贴一次。
NCM_MUSIC_U=
NCM_CSRF=

# -----------------------------------------------------------------------------
# 网易云音乐凭据：方法 B（手机号 + 密码 API 登录）
# -----------------------------------------------------------------------------
# 注意：网易云对账密登录有行为验证码风控（code 8821），首次登录大概率失败。
# 如果方法 A 已填，本节将被忽略。
NCM_PHONE=
NCM_PASSWORD=
NCM_COUNTRY_CODE=86


# =============================================================================
# 凭据缓存路径（一般不用改）
# =============================================================================
BILIBILI_CREDENTIAL_FILE=backend/secrets/bilibili_credential.json
NCM_CREDENTIAL_FILE=backend/secrets/pyncm_credential.json
