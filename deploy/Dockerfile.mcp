# Multi-Persona Voice Agent — MCP Server
# Build: docker build -f deploy/Dockerfile.mcp --build-arg MCP_NAME=bilibili -t mcp-bilibili .
FROM python:3.11-slim

LABEL org.opencontainers.image.description="Multi-Persona Voice Agent MCP Server"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

ARG MCP_NAME=bilibili
ENV MCP_NAME=${MCP_NAME}

CMD ["sh", "-c", "python -m backend.mcp_servers.${MCP_NAME}"]
